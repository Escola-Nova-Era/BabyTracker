<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/screen_border"
    tools:context=".home.ui.TelaHomePrincipal">

    <!-- Linha guia da primeira parte -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_section1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.25" />

    <!-- Linha guia da segunda parte -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_section2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.63" />

    <LinearLayout
        android:id="@+id/quick_actions_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/guideline_section2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_quick_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="QUICK ACTIONS"
            android:textStyle="bold"
            android:textSize="16sp"
            android:paddingBottom="12dp" />

        <GridLayout
            android:id="@+id/grid_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:alignmentMode="alignMargins"
            android:useDefaultMargins="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_1"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:backgroundTint="#1573BF"
                android:text="Add Feeding"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:icon="@drawable/outline_child_care_24"
                app:iconGravity="top"
                app:iconSize="25dp"
                app:iconPadding="8dp"
                />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_2"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:backgroundTint="#43AB47"
                android:text="Add Diaper"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:icon="@drawable/outline_favorite_24"
                app:iconGravity="top"
                app:iconSize="25dp"
                app:iconPadding="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_3"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:backgroundTint="#8951EB"
                android:text="Sleep/Wake"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:icon="@drawable/outline_bedtime_24"
                app:iconGravity="top"
                app:iconSize="25dp"
                app:iconPadding="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_4"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:backgroundTint="#FF5722"
                android:text="Add Bath"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:icon="@drawable/outline_bathtub_24"
                app:iconGravity="top"
                app:iconSize="25dp"
                app:iconPadding="8dp" />

        </GridLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>